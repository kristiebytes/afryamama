rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function authEmail() {
      return request.auth.token.email;
    }

    function isOwnerByEmail(data) {
      return signedIn() && (
        data.email == authEmail() ||
        data.Email == authEmail() ||
        data.userEmail == authEmail() ||
        data.user_email == authEmail() ||
        data.motherEmail == authEmail() ||
        data.mother_email == authEmail()
      );
    }

    match /mothers/{docId} {
      allow read: if isOwnerByEmail(resource.data);
      allow create: if isOwnerByEmail(request.resource.data);
      allow update: if isOwnerByEmail(resource.data) && isOwnerByEmail(request.resource.data);
      allow delete: if isOwnerByEmail(resource.data);
    }

    match /children/{docId} {
      allow read: if isOwnerByEmail(resource.data);
      allow create: if isOwnerByEmail(request.resource.data);
      allow update: if isOwnerByEmail(resource.data) && isOwnerByEmail(request.resource.data);
      allow delete: if isOwnerByEmail(resource.data);
    }

    match /doctor_switch_requests/{docId} {
      allow create: if signedIn() && (
        request.resource.data.motherEmail == authEmail() ||
        request.resource.data.email == authEmail() ||
        request.resource.data.userEmail == authEmail()
      );
      allow read: if signedIn() && (
        resource.data.motherEmail == authEmail() ||
        resource.data.email == authEmail() ||
        resource.data.userEmail == authEmail()
      );
      allow update, delete: if false;
    }

    match /doctors/{docId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /Doctors/{docId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /notifications/{docId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /Notifications/{docId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
